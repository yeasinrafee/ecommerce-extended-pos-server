model ProductTag {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  

  tagsOnProducts TagsOnProducts[]
}

model BlogTag {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
 

  tagsOnBlogs TagsOnBlogs[]
}

model TagsOnBlogs {
    blog       Blog     @relation(fields: [blogId], references: [id])
    blogId     String
    tag        BlogTag  @relation(fields: [tagId], references: [id])
    tagId      String
    assignedAt DateTime @default(now())

    @@id([blogId, tagId])
}

model TagsOnProducts {
  product   Product    @relation(fields: [productId], references: [id])
  productId String
  tag       ProductTag @relation(fields: [tagId], references: [id])
  tagId     String
  assignedAt DateTime  @default(now())

  @@id([productId, tagId])
}