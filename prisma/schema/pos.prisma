model PosOrder {
    id             String          @id @default(uuid())
    userId         String
    user           User            @relation(fields: [userId], references: [id])
    invoiceNumber  String          @unique
    baseAmount     Float
    finalAmount    Float
    orderDiscountType DiscountType @default(NONE)
    orderDiscountValue Float       @default(0)
    createdAt      DateTime        @default(now())
    updatedAt      DateTime        @updatedAt
    deletedAt      DateTime?
    storeId        String?
    paymentStatus         PaymentStatus   @default(PENDING)
    store          Store?          @relation(fields: [storeId], references: [id])
    posOrderItems  PosOrderItem[]
    globalPayments GlobalPayment[]
}

model PosOrderItem {
    id            String        @id @default(uuid())
    posOrderId    String
    posOrder      PosOrder      @relation(fields: [posOrderId], references: [id])
    productId     String
    product       Product       @relation(fields: [productId], references: [id])
    quantity      Int
    Baseprice     Float
    finalPrice    Float
    discountType  DiscountType?
    discountValue Float?
    createdAt     DateTime      @default(now())
    updatedAt     DateTime      @updatedAt
    deletedAt     DateTime?

    variations PosOrderItemVariation[]

    @@index([posOrderId])
    @@index([productId])
}

model PosOrderItemVariation {
    id                 String           @id @default(uuid())
    orderItem          PosOrderItem     @relation(fields: [orderItemId], references: [id])
    orderItemId        String
    productVariation   ProductVariation @relation(fields: [productVariationId], references: [id])
    productVariationId String
    createdAt          DateTime         @default(now())
    updatedAt          DateTime         @updatedAt
    deletedAt          DateTime?

    @@unique([orderItemId, productVariationId])
}
